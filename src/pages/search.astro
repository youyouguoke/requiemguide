---
import MainLayout from '../layouts/MainLayout.astro';

const title = 'Search Requiem Guide';
const description = 'Search walkthroughs, puzzle solutions, boss strategies, weapons, characters, and more for Resident Evil Requiem.';
---

<MainLayout
  title={title}
  description={description}
  noindex={true}
  currentPath="/search"
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <header class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-horror-text mb-4">Search the Guide</h1>
      <p class="text-horror-text-secondary">Find walkthroughs, puzzles, bosses, weapons, and characters.</p>
    </header>

    <div id="search" class="pagefind-ui"></div>
  </div>

  <script is:inline data-pagefind-ignore>
    (async () => {
      const PagefindUI = (await import('/pagefind/pagefind-ui.js')).PagefindUI;
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
        excerptLength: 24,
        debounceTimeout: 200,
        translations: {
          placeholder: 'Search guides, puzzles, bosses...',
          zero_results: 'No results found. Try a different keyword.',
          many_results: '# results for your search',
        },
      });
    })();
  </script>

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
</MainLayout>
