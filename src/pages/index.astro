---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import HubCard from '../components/HubCard.astro';
import GuideCard from '../components/GuideCard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import ProgressTracker from '../components/ProgressTracker.astro';
import { SITE } from '../lib/config';

const title = SITE.title;
const description = 'Complete Resident Evil Requiem survival guide with chapter walkthroughs, puzzle solutions, boss strategies, weapon locations, character guides, endings and secrets.';

const guides = await getCollection('guide');
const walkthroughChapters = guides
  .filter((g) => g.data.category === 'walkthrough')
  .sort((a, b) => (b.data.chapter || 0) - (a.data.chapter || 0));

const latestWalkthroughs = walkthroughChapters.slice(0, 3);

const puzzles = await getCollection('puzzle');
const latestPuzzles = puzzles.slice(0, 3);

const bosses = await getCollection('boss');
const latestBosses = bosses.slice(0, 3);

const progressChapters = walkthroughChapters
  .sort((a, b) => (a.data.chapter || 0) - (b.data.chapter || 0))
  .map((g) => ({
    slug: g.slug,
    title: g.data.title,
    href: `/walkthrough/${g.slug}`,
  }));

const keywords = [
  'resident evil requiem walkthrough',
  'resident evil requiem guide',
  'resident evil requiem puzzle solutions',
  'resident evil requiem boss guide',
  'resident evil requiem weapons',
  'resident evil requiem characters',
  'resident evil requiem endings',
  'resident evil requiem enemies',
  'resident evil requiem items',
];

const faqs = [
  {
    question: 'What is Resident Evil Requiem?',
    answer: 'Resident Evil Requiem is a survival horror game guide covering walkthroughs, puzzles, bosses, enemies, items, weapons, characters, and story information.',
  },
  {
    question: 'Does Resident Evil Requiem have multiple endings?',
    answer: 'Yes. Resident Evil Requiem features multiple endings based on key choices, collectibles, and final boss conditions. Our endings guide explains how to unlock each one.',
  },
  {
    question: 'Who are the main characters in Resident Evil Requiem?',
    answer: 'The story follows a cast of survivors tied to the outbreak. Our character database covers their roles, backstories, and relationships.',
  },
  {
    question: 'How do I beat the bosses in Resident Evil Requiem?',
    answer: 'Each boss has unique weaknesses and attack patterns. Browse our boss guides for detailed strategies, recommended weapons, and combat tips.',
  },
  {
    question: 'Where do I find all puzzle solutions?',
    answer: 'Our puzzle database lists every puzzle with step-by-step solutions, including safe codes, door locks, and key item requirements.',
  },
  {
    question: 'What weapons are available in Resident Evil Requiem?',
    answer: 'The weapons database covers all firearms, melee weapons, and upgrades, including stats, locations, and best-use scenarios.',
  },
  {
    question: 'How long is Resident Evil Requiem?',
    answer: 'A standard playthrough takes roughly 10–14 hours depending on difficulty and how thoroughly you explore. Completionists hunting every puzzle, collectible, and alternate ending can expect closer to 20–25 hours.',
  },
  {
    question: 'What are the best weapons in Resident Evil Requiem?',
    answer: 'The best weapon depends on your inventory and the encounter. Shotguns excel at close range, magnums handle bosses, and rifles are ideal for distant enemies. Our weapons database ranks every option by damage, ammo efficiency, and location.',
  },
  {
    question: 'Where do I find healing items and herbs?',
    answer: 'Green herbs are the most common healing source and appear near save rooms and high-traffic corridors. Red herbs boost healing when combined with green, and first aid sprays are usually hidden in optional rooms. The item database lists every herb and healing location.',
  },
  {
    question: 'Are there difficulty settings in Resident Evil Requiem?',
    answer: 'Yes. Multiple difficulty options affect enemy health, item availability, and autosave behavior. Our walkthrough notes route changes and resource adjustments for each mode.',
  },
];
---

<MainLayout
  title={title}
  description={description}
  keywords={keywords}
  currentPath="/"
  type="website"
  image="/images/requiem_survival_guide_homepage_024.jpg"
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-horror-border min-h-[80vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/requiem_survival_guide_homepage_024.jpg"
        alt="Resident Evil Requiem atmospheric gothic mansion"
        width="512"
        height="286"
        loading="eager"
        fetchpriority="high"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-horror-bg/60"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-horror-bg via-horror-bg/80 to-horror-bg/40"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-horror-bg via-transparent to-horror-bg/30"></div>
      
      <div class="absolute inset-0 opacity-10 pointer-events-none">
        <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-horror-red rounded-full blur-[120px]"></div>
        <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-horror-red/60 rounded-full blur-[140px]"></div>
      </div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-24 lg:py-32 w-full">
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-2 mb-6">
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-horror-green/15 text-horror-green border border-horror-green/30 text-sm font-semibold">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
            Updated July 2026
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-horror-blue/15 text-horror-blue border border-horror-blue/30 text-sm font-semibold">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2a10 10 0 1 0 10 10H12V2z" />
              <path d="M12 12 2.5 8.5" />
            </svg>
            AI-powered summaries
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-horror-red/15 text-horror-red border border-horror-red/30 text-sm font-semibold">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
              <circle cx="12" cy="12" r="3" />
            </svg>
            Spoiler-free sections
          </span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-horror-text leading-[1.1] mb-6">
          Resident Evil Requiem
          <br />
          <span class="text-horror-red">Survival Guide</span>
        </h1>
        <p class="text-lg sm:text-xl lg:text-2xl text-horror-text-secondary mb-4 max-w-2xl">
          Complete walkthroughs, puzzle solutions, boss strategies, weapon locations, character guides, endings and secrets for the ultimate Resident Evil experience.
        </p>
        <p class="text-base sm:text-lg text-horror-text-muted mb-10 max-w-2xl">
          Built as a game database, not a blog. Find chapter-by-chapter guides, puzzle answers, enemy and item data, and story analysis all in one place.
        </p>

        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
          <a href="/walkthrough" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-horror-red text-white font-bold rounded-xl hover:bg-horror-red-light transition-colors shadow-lg shadow-horror-red/25 text-base w-full sm:w-auto">
            Start Walkthrough
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </a>
          <a href="/search" class="inline-flex items-center justify-center gap-2 text-horror-text-secondary hover:text-horror-text font-semibold transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.3-4.3" />
            </svg>
            Search guides
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Hubs -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="mb-8 sm:mb-10">
      <h2 class="text-2xl sm:text-3xl font-bold text-horror-text mb-3">Browse the Complete Database</h2>
      <p class="text-horror-text-secondary max-w-3xl">
        Navigate directly to walkthroughs, puzzle solutions, boss strategies, or database entries. Every hub links deeper into specific guides.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
      <HubCard
        href="/walkthrough"
        title="Walkthrough"
        description="Step-by-step chapter guides."
        icon="lucide:book-open"
        image="/images/requiem_survival_guide_homepage_028.jpg"
      />
      <HubCard
        href="/puzzles"
        title="Puzzles"
        description="Safe codes and solutions."
        icon="lucide:puzzle"
        image="/images/requiem_survival_guide_homepage_029.jpg"
      />
      <HubCard
        href="/bosses"
        title="Bosses"
        description="Weaknesses and strategies."
        icon="lucide:skull"
        image="/images/requiem_survival_guide_homepage_030.jpg"
      />
      <HubCard
        href="/weapons"
        title="Weapons"
        description="Stats, locations, upgrades."
        icon="lucide:crosshair"
        image="/images/requiem_survival_guide_homepage_031.jpg"
      />
      <HubCard
        href="/enemies"
        title="Enemies"
        description="Threat profiles and tactics."
        icon="lucide:bug"
        image="/images/enemy_shambler.jpg"
      />
      <HubCard
        href="/items"
        title="Items"
        description="Key items and collectibles."
        icon="lucide:box"
        image="/images/item_east-wing-key.jpg"
      />
      <HubCard
        href="/characters"
        title="Characters"
        description="Profiles and story roles."
        icon="lucide:users"
        image="/images/requiem_survival_guide_grace_ashcroft_profile_017.jpg"
      />
      <HubCard
        href="/story/endings"
        title="Story & Endings"
        description="Ending explanations and lore."
        icon="lucide:film"
        image="/images/requiem_survival_guide_ending_explained_010.jpg"
      />
    </div>
  </section>

  <!-- Walkthrough + Progress -->
  <section class="border-y border-horror-border bg-horror-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4 mb-8">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-horror-text mb-3">Resident Evil Requiem Walkthrough</h2>
          <p class="text-horror-text-secondary max-w-2xl">
            Chapter-by-chapter guides with objectives, items, puzzles, enemies, and boss encounters.
          </p>
        </div>
        <a href="/walkthrough" class="inline-flex items-center gap-2 self-start px-4 py-2 rounded-lg border border-horror-border text-horror-text font-medium hover:border-horror-red hover:text-horror-red transition-colors">
          All chapters
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 sm:gap-6">
        <div class="lg:col-span-2">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
            {latestWalkthroughs.map((guide) => (
              <GuideCard
                href={`/walkthrough/${guide.slug}`}
                title={guide.data.title}
                category="Walkthrough"
                description={guide.data.description || `Chapter ${guide.data.chapter} walkthrough`}
                image={guide.data.image || '/images/requiem_survival_guide_homepage_025.jpg'}
              />
            ))}
          </div>
        </div>

        <div class="lg:col-span-1">
          <ProgressTracker chapters={progressChapters} />
        </div>
      </div>
    </div>
  </section>

  <!-- Puzzle Solutions -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
      <div>
        <h2 class="text-2xl sm:text-3xl font-bold text-horror-text mb-3">Puzzle Solutions</h2>
        <p class="text-horror-text-secondary max-w-2xl">
          Safe codes, door locks, and environmental riddles with step-by-step answers and rewards.
        </p>
      </div>
      <a href="/puzzles" class="inline-flex items-center gap-2 self-start px-4 py-2 rounded-lg border border-horror-border text-horror-text font-medium hover:border-horror-red hover:text-horror-red transition-colors">
        Browse all puzzles
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14" />
          <path d="m12 5 7 7-7 7" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
      {latestPuzzles.map((puzzle) => (
        <GuideCard
          href={`/puzzles/${puzzle.slug}`}
          title={puzzle.data.title}
          category="Puzzle"
          description={puzzle.data.description || `Solution for ${puzzle.data.title}`}
          image={puzzle.data.image || '/images/requiem_survival_guide_homepage_026.jpg'}
        />
      ))}
    </div>
  </section>

  <!-- Boss Guides -->
  <section class="border-y border-horror-border bg-horror-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-horror-text mb-3">Boss Guides</h2>
          <p class="text-horror-text-secondary max-w-2xl">
            Weaknesses, attack patterns, and recommended weapons for every boss encounter.
          </p>
        </div>
        <a href="/bosses" class="inline-flex items-center gap-2 self-start px-4 py-2 rounded-lg border border-horror-border text-horror-text font-medium hover:border-horror-red hover:text-horror-red transition-colors">
          All bosses
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
        {latestBosses.map((boss) => (
          <GuideCard
            href={`/bosses/${boss.slug}`}
            title={boss.data.title}
            category="Boss"
            description={boss.data.description || `How to beat ${boss.data.title}`}
            image={boss.data.image || '/images/requiem_survival_guide_homepage_027.jpg'}
            variant="boss"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Database -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="mb-8 sm:mb-10">
      <h2 class="text-2xl sm:text-3xl font-bold text-horror-text mb-3">Database</h2>
      <p class="text-horror-text-secondary max-w-3xl">
        Compare weapons, check enemy weaknesses, review character roles, and track key items.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
      <HubCard
        href="/weapons"
        title="Weapons"
        description="Stats, locations, and best uses."
        icon="lucide:crosshair"
        image="/images/requiem_survival_guide_weapons_database_058.jpg"
      />
      <HubCard
        href="/characters"
        title="Characters"
        description="Profiles and story roles."
        icon="lucide:users"
        image="/images/requiem_survival_guide_grace_ashcroft_profile_017.jpg"
      />
      <HubCard
        href="/items"
        title="Items"
        description="Key items and collectibles."
        icon="lucide:box"
        image="/images/item_east-wing-key.jpg"
      />
      <HubCard
        href="/enemies"
        title="Enemies"
        description="Threat profiles and tactics."
        icon="lucide:bug"
        image="/images/enemy_shambler.jpg"
      />
    </div>
  </section>

  <!-- Story & Endings -->
  <section class="border-y border-horror-border bg-horror-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-horror-text mb-4">Story & Endings Explained</h2>
          <p class="text-horror-text-secondary mb-6">
            All endings, character arcs, and hidden lore. Understand which decisions matter and how to unlock the true ending.
          </p>
          <a href="/story/endings" class="inline-flex items-center gap-2 px-5 py-3 rounded-lg bg-horror-red text-white font-semibold hover:bg-horror-red-light transition-colors">
            Explore story & endings
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        </div>

        <div class="rounded-2xl overflow-hidden border border-horror-border shadow-2xl shadow-black/40">
          <img
            src="/images/requiem_survival_guide_ending_explained_010.jpg"
            alt="Resident Evil Requiem story and endings"
            width="512"
            height="286"
            loading="lazy"
            class="w-full h-auto object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="mb-8 sm:mb-10">
      <h2 class="text-2xl sm:text-3xl font-bold text-horror-text mb-3">Frequently Asked Questions</h2>
      <p class="text-horror-text-secondary max-w-3xl">
        Quick answers to common questions. Click any question to expand the answer.
      </p>
    </div>

    <FAQAccordion faqs={faqs} />
  </section>

  <!-- Final CTA -->
  <section class="border-y border-horror-border bg-horror-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16 text-center">
      <div class="inline-flex items-center justify-center p-3 rounded-full bg-horror-red/10 text-horror-red mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
        </svg>
      </div>
      <h2 class="text-2xl sm:text-3xl font-bold text-horror-text mb-4">Found something missing?</h2>
      <p class="text-horror-text-secondary mb-8 max-w-xl mx-auto">
        Have a correction or suggestion? Send us an email and help make this guide better for everyone.
      </p>
      <a
        href="mailto:hello@requiemguide.com"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-horror-red text-white font-semibold rounded-xl hover:bg-horror-red-light transition-colors"
      >
        Contact Us
      </a>
    </div>
  </section>
</MainLayout>
