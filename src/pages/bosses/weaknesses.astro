---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const bosses = await getCollection('boss');
const sortedByDifficulty = bosses.sort((a, b) => {
  const order = { Easy: 1, Medium: 2, 'Medium-Hard': 3, Hard: 4, 'Very High': 5, Extreme: 6 };
  return (order[a.data.difficulty] || 0) - (order[b.data.difficulty] || 0);
});

const title = 'Resident Evil Requiem Boss Weaknesses - Full Database';
const description = 'Full Resident Evil Requiem boss weakness database: every boss, weak points, counter strategies, best weapons, and how to exploit each vulnerability.';

const keywords = [
  'resident evil requiem boss weaknesses',
  'resident evil requiem weakness chart',
  'resident evil requiem boss weak points',
  'resident evil requiem boss counter',
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://requiemguide.com' },
    { '@type': 'ListItem', position: 2, name: 'Bosses', item: 'https://requiemguide.com/bosses' },
    { '@type': 'ListItem', position: 3, name: 'Boss Weaknesses', item: 'https://requiemguide.com/bosses/weaknesses' },
  ],
};

const tableSchema = {
  '@context': 'https://schema.org',
  '@type': 'Table',
  about: 'Resident Evil Requiem boss weaknesses and counter strategies',
};
---

<MainLayout
  title={title}
  description={description}
  keywords={keywords}
  currentPath="/bosses/weaknesses"
  extraSchema={[breadcrumbSchema, tableSchema]}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb
      items={[
        { label: 'Bosses', href: '/bosses' },
        { label: 'Boss Weaknesses', href: '/bosses/weaknesses' },
      ]}
    />

    <header class="mb-12">
      <span class="text-horror-red font-semibold tracking-widest uppercase text-sm mb-4">Database</span>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-horror-text mb-4">Resident Evil Requiem Boss Weaknesses</h1>
      <p class="text-xl text-horror-text-secondary max-w-3xl">{description}</p>
    </header>

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-horror-text mb-4">About This Boss Weakness Database</h2>
      <p class="text-horror-text-secondary leading-relaxed mb-4">
        Every boss in Resident Evil Requiem has a specific weakness or exploitable weak point. This database lists each boss, its difficulty, the exact weakness, the recommended weapon, and how to use that weakness during the fight. Use this chart to plan your loadout before each major encounter.
      </p>
      <p class="text-horror-text-secondary leading-relaxed">
        Click any boss name to see the full boss guide with attack patterns, step-by-step strategy, rewards, and Hardcore tips.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-horror-text mb-6">Boss Weakness Chart</h2>

      <div class="overflow-x-auto rounded-xl border border-horror-border">
        <table class="w-full text-left text-sm">
          <thead class="bg-horror-surface text-horror-text-muted uppercase text-xs font-semibold">
            <tr>
              <th class="px-4 py-3">Boss</th>
              <th class="px-4 py-3">Difficulty</th>
              <th class="px-4 py-3">Weakness</th>
              <th class="px-4 py-3">Best Weapon</th>
              <th class="px-4 py-3">Location</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-horror-border">
            {sortedByDifficulty.map((boss) => (
              <tr class="hover:bg-horror-surface/50 transition-colors">
                <td class="px-4 py-3">
                  <a href={`/bosses/${boss.slug}`} class="font-semibold text-horror-text hover:text-horror-red transition-colors">
                    {boss.data.title}
                  </a>
                </td>
                <td class="px-4 py-3 text-horror-text-secondary">{boss.data.difficulty}</td>
                <td class="px-4 py-3 text-horror-red font-semibold">{boss.data.weakness}</td>
                <td class="px-4 py-3 text-horror-text-secondary">{boss.data.recommendedWeapon}</td>
                <td class="px-4 py-3 text-horror-text-secondary">{boss.data.location}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <div class="rounded-xl border border-horror-border bg-horror-surface p-5 sm:p-6">
      <a href="/bosses" class="text-horror-red font-semibold hover:underline">← All Boss Guides</a>
    </div>
  </div>
</MainLayout>
