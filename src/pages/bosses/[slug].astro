---
import { getCollection, type CollectionEntry } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import GuideCard from '../../components/GuideCard.astro';
import FAQSection from '../../components/FAQSection.astro';
import { Icon } from 'astro-icon/components';

export async function getStaticPaths() {
  const bosses = await getCollection('boss');
  return bosses.map((boss) => ({
    params: { slug: boss.slug },
    props: { boss },
  }));
}

interface Props {
  boss: CollectionEntry<'boss'>;
}

const { boss } = Astro.props;
const { Content } = await boss.render();

const allBosses = await getCollection('boss');
const allWeapons = await getCollection('weapon');
const allGuides = await getCollection('guide');

const chapterGuide = boss.data.location ? allGuides.find((g) => g.data.category === 'walkthrough' && g.data.boss?.toLowerCase() === boss.data.title?.toLowerCase()) : null;
const recommendedWeapon = boss.data.recommendedWeapon ? allWeapons.find((w) => boss.data.recommendedWeapon?.toLowerCase().includes(w.data.title.toLowerCase()) || w.data.title.toLowerCase().includes(boss.data.recommendedWeapon?.toLowerCase())) : null;

const relatedBosses = allBosses.filter((b) => b.slug !== boss.slug).slice(0, 3);

const pageTitle = `${boss.data.title} - Weakness, Strategy & How to Beat`;
const pageDescription = `Complete ${boss.data.title} boss guide for Resident Evil Requiem: location, weakness, attack patterns, best weapons, and step-by-step strategy to win the fight.`;

const breadcrumbItems = [
  { label: 'Bosses', href: '/bosses' },
  { label: boss.data.title, href: `/bosses/${boss.slug}` },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://requiemguide.com' },
    { '@type': 'ListItem', position: 2, name: 'Bosses', item: 'https://requiemguide.com/bosses' },
    { '@type': 'ListItem', position: 3, name: boss.data.title, item: `https://requiemguide.com/bosses/${boss.slug}` },
  ],
};

const faqSchema = boss.data.faq?.length ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: boss.data.faq.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
} : null;

const keywords = [
  ...new Set([
    `${boss.data.title} boss guide`,
    `${boss.data.title} weakness`,
    `how to beat ${boss.data.title}`,
    `resident evil requiem ${boss.data.title}`,
    `resident evil requiem boss guide`,
    `resident evil requiem boss fight`,
    ...(boss.data.keywords || []),
  ]),
];
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  keywords={keywords}
  type="article"
  modifiedTime={boss.data.updated}
  currentPath={`/bosses/${boss.slug}`}
  extraSchema={[breadcrumbSchema, faqSchema].filter(Boolean)}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <article class="max-w-none">
      <!-- Hero Header -->
      <header class="relative mb-8 rounded-2xl overflow-hidden border border-horror-border">
        <div class="relative h-64 sm:h-80">
          <img
            src={boss.data.image || '/images/requiem_survival_guide_the_executioner_boss_strategy_049.jpg'}
            alt={`${boss.data.title} boss guide in Resident Evil Requiem - ${boss.data.location}`}
            width="512"
            height="286"
            loading="eager"
            fetchpriority="high"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-horror-bg via-horror-bg/60 to-transparent"></div>
        </div>

        <div class="p-6 sm:p-8">
          <div class="flex items-center gap-3 mb-4">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-horror-red/20 text-horror-red pulse-red">Boss</span>
            {boss.data.difficulty && (
              <span class="text-sm text-horror-text-muted">Difficulty: {boss.data.difficulty}</span>
            )}
          </div>

          <h1 class="text-4xl sm:text-5xl font-extrabold text-horror-text mb-4">
            {boss.data.title}
          </h1>

          {boss.data.description && <p class="text-xl text-horror-text-secondary">{boss.data.description}</p>}
        </div>
      </header>

      <!-- Overview Stats -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
        {boss.data.location && (
          <div class="bg-horror-surface border border-horror-border rounded-xl p-4">
            <div class="flex items-center gap-2 text-xs font-semibold text-horror-text-muted uppercase tracking-wider mb-1">
              <Icon name="lucide:map-pin" class="w-3.5 h-3.5" />
              Location
            </div>
            <p class="text-horror-text font-semibold">{boss.data.location}</p>
          </div>
        )}
        {boss.data.hp && (
          <div class="bg-horror-surface border border-horror-border rounded-xl p-4">
            <div class="flex items-center gap-2 text-xs font-semibold text-horror-text-muted uppercase tracking-wider mb-1">
              <Icon name="lucide:heart" class="w-3.5 h-3.5" />
              HP
            </div>
            <p class="text-horror-text font-semibold">{boss.data.hp}</p>
          </div>
        )}
        {boss.data.weakness && (
          <div class="bg-horror-surface border border-horror-border rounded-xl p-4">
            <div class="flex items-center gap-2 text-xs font-semibold text-horror-text-muted uppercase tracking-wider mb-1">
              <Icon name="lucide:target" class="w-3.5 h-3.5" />
              Weakness
            </div>
            <p class="text-horror-red font-semibold">{boss.data.weakness}</p>
          </div>
        )}
        {boss.data.recommendedWeapon && (
          <div class="bg-horror-surface border border-horror-border rounded-xl p-4">
            <div class="flex items-center gap-2 text-xs font-semibold text-horror-text-muted uppercase tracking-wider mb-1">
              <Icon name="lucide:crosshair" class="w-3.5 h-3.5" />
              Best Weapon
            </div>
            <p class="text-horror-green font-semibold">{boss.data.recommendedWeapon}</p>
          </div>
        )}
        {boss.data.reward && (
          <div class="bg-horror-surface border border-horror-border rounded-xl p-4">
            <div class="flex items-center gap-2 text-xs font-semibold text-horror-text-muted uppercase tracking-wider mb-1">
              <Icon name="lucide:gift" class="w-3.5 h-3.5" />
              Reward
            </div>
            <p class="text-horror-green font-semibold">{boss.data.reward}</p>
          </div>
        )}
      </div>

      <!-- Overview -->
      <div class="rounded-xl border border-horror-border bg-horror-surface p-5 sm:p-6 mb-8">
        <div class="flex items-center gap-2 text-horror-text font-bold text-xl mb-4">
          <Icon name="lucide:info" class="w-5 h-5 text-horror-red" />
          Overview
        </div>
        <div class="prose-horror max-w-none text-horror-text-secondary">
          <Content />
        </div>
      </div>

      <!-- Weakness -->
      <section class="mb-8">
        <div class="flex items-center gap-2 text-horror-text font-bold text-xl mb-4">
          <Icon name="lucide:target" class="w-5 h-5 text-horror-red" />
          Weakness
        </div>

        <div class="rounded-xl border border-horror-red/30 bg-horror-red/5 p-5 sm:p-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <div class="text-xs font-semibold text-horror-red uppercase tracking-wider mb-1">Primary Weakness</div>
              <div class="text-horror-text font-bold">{boss.data.weakness || 'See strategy section'}</div>
            </div>
            {boss.data.weaknessEffect && (
              <div>
                <div class="text-xs font-semibold text-horror-red uppercase tracking-wider mb-1">Effect</div>
                <div class="text-horror-text-secondary">{boss.data.weaknessEffect}</div>
              </div>
            )}
          </div>
        </div>

        {recommendedWeapon && (
          <div class="mt-4 p-4 rounded-lg border border-horror-border bg-horror-bg">
            <div class="text-sm text-horror-text-secondary mb-1">
              Recommended weapon: <span class="text-horror-text font-semibold">{boss.data.recommendedWeapon}</span>
            </div>
            <a
              href={`/weapons/${recommendedWeapon.slug}`}
              class="inline-flex items-center gap-1 text-sm font-semibold text-horror-red hover:underline"
            >
              View {recommendedWeapon.data.title} weapon guide
              <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
          </div>
        )}
      </section>

      <!-- Attack Patterns -->
      <section class="mb-8">
        <div class="flex items-center gap-2 text-horror-text font-bold text-xl mb-4">
          <Icon name="lucide:swords" class="w-5 h-5 text-horror-red" />
          Attack Patterns
        </div>

        {boss.data.attackPatterns && boss.data.attackPatterns.length > 0 ? (
          <div class="space-y-4">
            {boss.data.attackPatterns.map((attack) => (
              <div class="rounded-xl border border-horror-border bg-horror-surface p-5">
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
                  <div class="font-bold text-horror-text">{attack.name}</div>
                </div>
                <p class="text-horror-text-secondary text-sm mb-2">{attack.description}</p>
                {attack.counter && (
                  <div class="text-sm">
                    <span class="text-horror-red font-semibold">Counter: </span>
                    <span class="text-horror-text-secondary">{attack.counter}</span>
                  </div>
                )}
              </div>
            ))}
          </div>
        ) : (
          <p class="text-horror-text-secondary">Check the full written guide below for attack details.</p>
        )}
      </section>

      <!-- Strategy Steps -->
      <section class="mb-8">
        <div class="flex items-center gap-2 text-horror-text font-bold text-xl mb-4">
          <Icon name="lucide:list-ordered" class="w-5 h-5 text-horror-red" />
          How to Beat {boss.data.title}
        </div>

        {boss.data.strategySteps && boss.data.strategySteps.length > 0 ? (
          <div class="space-y-6">
            {boss.data.strategySteps.map((step, index) => (
              <div class="group relative rounded-xl border border-horror-border bg-horror-surface p-5 sm:p-6">
                <div class="flex items-start gap-4">
                  <div class="flex-shrink-0 w-10 h-10 rounded-full bg-horror-red/10 text-horror-red flex items-center justify-center font-black">
                    {index + 1}
                  </div>
                  <div class="flex-1">
                    <h3 class="text-lg font-bold text-horror-text mb-2">{step.title}</h3>
                    <p class="text-horror-text-secondary leading-relaxed">{step.detail}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p class="text-horror-text-secondary">Strategy details are in the overview section above.</p>
        )}
      </section>

      <!-- Hardcore Tips -->
      {boss.data.hardcoreTips && boss.data.hardcoreTips.length > 0 && (
        <section class="mb-8">
          <div class="flex items-center gap-2 text-horror-text font-bold text-xl mb-4">
            <Icon name="lucide:skull" class="w-5 h-5 text-horror-red" />
            Hardcore Mode Tips
          </div>
          
          <ul class="space-y-2 list-disc pl-5 text-horror-text-secondary">
            {boss.data.hardcoreTips.map((tip) => <li>{tip}</li>)}
          </ul>
        </section>
      )}

      <!-- FAQ -->
      {boss.data.faq?.length > 0 && (
        <FAQSection faqs={boss.data.faq} />
      )}

      <!-- E-E-A-T About -->
      <section class="rounded-xl border border-horror-border bg-horror-surface p-5 sm:p-6 mb-8">
        <h2 class="text-2xl font-bold text-horror-text mb-4">About This Boss Guide</h2>
        <p class="text-horror-text-secondary leading-relaxed mb-4">
          This {boss.data.title} boss guide is part of the Requiem Guide database. We test each boss on multiple difficulties to record accurate attack patterns, weaknesses, and weapon recommendations.
        </p>
        <p class="text-horror-text-secondary leading-relaxed">
          For the full chapter context, check the linked walkthrough. For weapon stats and locations, visit the weapons guide.
        </p>
      </section>

      <!-- Related Links -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
        {chapterGuide && (
          <a href={`/walkthrough/${chapterGuide.slug}`} class="group p-4 rounded-xl border border-horror-border bg-horror-surface hover:border-horror-red/50 transition-all">
            <div class="text-xs font-semibold text-horror-text-muted uppercase tracking-wider mb-1">Chapter Walkthrough</div>
            <div class="font-bold text-horror-text group-hover:text-horror-red transition-colors">{chapterGuide.data.title}</div>
            <div class="text-sm text-horror-text-secondary mt-1">View the full chapter guide for this boss.</div>
          </a>
        )}
        <a href="/weapons" class="group p-4 rounded-xl border border-horror-border bg-horror-surface hover:border-horror-red/50 transition-all">
          <div class="text-xs font-semibold text-horror-text-muted uppercase tracking-wider mb-1">Weapons Guide</div>
          <div class="font-bold text-horror-text group-hover:text-horror-red transition-colors">Best Weapons for Bosses</div>
          <div class="text-sm text-horror-text-secondary mt-1">Compare stats, locations, and upgrades.</div>
        </a>
      </div>

      <!-- Related Bosses -->
      {relatedBosses.length > 0 && (
        <div class="mt-12">
          <h2 class="text-2xl font-bold text-horror-text mb-6">More Boss Guides</h2>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {relatedBosses.map((relatedBoss) => (
              <GuideCard
                href={`/bosses/${relatedBoss.slug}`}
                title={`${relatedBoss.data.title} Boss Guide`}
                category="Boss"
                description={relatedBoss.data.description || `How to beat ${relatedBoss.data.title}`}
                image={relatedBoss.data.image}
                variant="boss"
              />
            ))}
          </div>
        </div>
      )}
    </article>
  </div>
</MainLayout>
