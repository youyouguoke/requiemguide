---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { Icon } from 'astro-icon/components';

const characters = await getCollection('character');

const title = 'Resident Evil Requiem Character Timeline - Story Order & Key Events';
const description = 'Resident Evil Requiem character timeline: follow Grace, Leon, Emily, and Elena through the story from the first outbreak to the final choice.';

const keywords = [
  'resident evil requiem character timeline',
  'resident evil requiem story order',
  'Grace Ashcroft timeline',
  'Resident Evil Requiem plot timeline',
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://requiemguide.com' },
    { '@type': 'ListItem', position: 2, name: 'Characters', item: 'https://requiemguide.com/characters' },
    { '@type': 'ListItem', position: 3, name: 'Character Timeline', item: 'https://requiemguide.com/characters/timeline' },
  ],
};
---

<MainLayout
  title={title}
  description={description}
  keywords={keywords}
  currentPath="/characters/timeline"
  extraSchema={[breadcrumbSchema]}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb
      items={[
        { label: 'Characters', href: '/characters' },
        { label: 'Character Timeline', href: '/characters/timeline' },
      ]}
    />

    <header class="mb-12">
      <span class="text-horror-red font-semibold tracking-widest uppercase text-sm mb-4">Character Timeline</span>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-horror-text mb-4">Resident Evil Requiem Character Timeline</h1>
      <p class="text-xl text-horror-text-secondary max-w-3xl">{description}</p>
    </header>

    <section class="mb-12">
      <p class="text-horror-text-secondary leading-relaxed">
        This timeline shows the key story events for each character in Resident Evil Requiem. Use it to understand how the characters' paths intersect and what drives them to the final choice at Elpis Laboratory.
      </p>
    </section>

    <section class="mb-12">
      <div class="space-y-8">
        {characters.map((character) => (
          <div class="rounded-xl border border-horror-border bg-horror-surface p-5 sm:p-6">
            <div class="flex items-center gap-4 mb-4">
              <img
                src={character.data.image}
                alt={`Resident Evil Requiem ${character.data.title} character timeline`}
                class="w-14 h-14 object-cover rounded-lg bg-horror-bg"
              />
              <div>
                <a href={`/characters/${character.slug}`} class="text-xl font-bold text-horror-text hover:text-horror-red transition-colors">
                  {character.data.title}
                </a>
                <div class="text-sm text-horror-text-secondary">{character.data.role}</div>
              </div>
            </div>

            <div class="space-y-3 relative pl-4">
              <div class="absolute left-0 top-0 bottom-0 w-0.5 bg-horror-border"></div>
              {character.data.timeline?.map((event, index) => (
                <div class="relative pl-6">
                  <div class="absolute left-[-5px] top-2 w-3 h-3 rounded-full bg-horror-red" style="margin-left: -0.3rem;"></div>
                  <div class="font-bold text-horror-text">{event.title}</div>
                  <p class="text-sm text-horror-text-secondary">{event.detail}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="rounded-xl border border-horror-border bg-horror-surface p-5 sm:p-6">
      <a href="/characters" class="text-horror-red font-semibold hover:underline">← All Characters Database</a>
    </div>
  </div>
</MainLayout>
