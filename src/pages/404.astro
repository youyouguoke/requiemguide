---
import MainLayout from '../layouts/MainLayout.astro';
import { Icon } from 'astro-icon/components';

const title = '404 - Page Not Found';
const description = 'The page you are looking for does not exist. Return to the Requiem Guide homepage.';
---

<MainLayout
  title={title}
  description={description}
  noindex={true}
  currentPath="/404"
>
  <section class="relative min-h-[calc(100vh-4rem)] flex items-center justify-center px-4 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/requiem_survival_guide_homepage_024.jpg"
        alt=""
        loading="eager"
        fetchpriority="high"
        class="w-full h-full object-cover opacity-20"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-horror-bg via-horror-bg/90 to-horror-bg"></div>
    </div>

    <div class="relative z-10 max-w-2xl mx-auto text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-horror-red/10 text-horror-red mb-8">
        <Icon name="lucide:skull" class="w-10 h-10" />
      </div>

      <p class="text-horror-red font-semibold tracking-[0.2em] uppercase text-sm mb-4">
        Error 404
      </p>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-horror-text leading-[1.1] mb-6">
        Page Not Found
      </h1>

      <p class="text-lg sm:text-xl text-horror-text-secondary mb-10 max-w-lg mx-auto">
        The page you requested has been consumed by the outbreak. It may have been moved, deleted, or never existed.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-horror-red text-white font-bold rounded-xl hover:bg-horror-red-light transition-colors shadow-lg shadow-horror-red/20">
          <Icon name="lucide:home" class="w-5 h-5" />
          Return Home
        </a>
        <a href="/search" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-horror-border bg-horror-surface/80 text-horror-text font-semibold rounded-xl hover:bg-horror-surface-hover transition-colors">
          <Icon name="lucide:search" class="w-5 h-5" />
          Search Guides
        </a>
      </div>

      <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-4 text-left">
        <a href="/walkthrough" class="group p-4 rounded-xl border border-horror-border bg-horror-surface/80 hover:bg-horror-surface hover:border-horror-red/50 transition-all">
          <div class="flex items-center gap-2 text-horror-red mb-2">
            <Icon name="lucide:book-open" class="w-4 h-4" />
            <span class="text-sm font-semibold">Walkthrough</span>
          </div>
          <p class="text-sm text-horror-text-secondary">Step-by-step chapter guides.</p>
        </a>
        <a href="/puzzles" class="group p-4 rounded-xl border border-horror-border bg-horror-surface/80 hover:bg-horror-surface hover:border-horror-red/50 transition-all">
          <div class="flex items-center gap-2 text-horror-red mb-2">
            <Icon name="lucide:puzzle" class="w-4 h-4" />
            <span class="text-sm font-semibold">Puzzles</span>
          </div>
          <p class="text-sm text-horror-text-secondary">Solutions for every puzzle.</p>
        </a>
        <a href="/bosses" class="group p-4 rounded-xl border border-horror-border bg-horror-surface/80 hover:bg-horror-surface hover:border-horror-red/50 transition-all">
          <div class="flex items-center gap-2 text-horror-red mb-2">
            <Icon name="lucide:skull" class="w-4 h-4" />
            <span class="text-sm font-semibold">Bosses</span>
          </div>
          <p class="text-sm text-horror-text-secondary">Weaknesses and strategies.</p>
        </a>
      </div>
    </div>
  </section>
</MainLayout>
