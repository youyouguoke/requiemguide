---
import MainLayout from '../layouts/MainLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FAQSection from '../components/FAQSection.astro';
import { Icon } from 'astro-icon/components';

const title = 'Resident Evil Requiem Secrets & Unlockables Guide | Requiem Guide';
const description = 'Discover Resident Evil Requiem secrets, unlockable weapons, hidden collectibles, safe codes, post-game rewards, and the choices needed to unlock every ending.';
const image = '/images/requiem_survival_guide_ending_explained_010.jpg';

const keywords = [
  'resident evil requiem secrets',
  'resident evil requiem unlockables',
  'resident evil requiem hidden collectibles',
  'resident evil requiem kotetsu unlock',
  'resident evil requiem safe codes',
  'resident evil requiem post game rewards',
  'resident evil requiem all endings',
];

const secrets = [
  {
    title: 'Kotetsu Unbreakable Melee Weapon',
    category: 'Unlockable Weapon',
    description: 'Complete the main campaign to unlock the Kotetsu, an unbreakable post-game melee weapon. It usually appears in the item box during New Game+ or challenge runs.',
    href: '/weapons/kotetsu',
    image: '/images/requiem_survival_guide_weapons_database_058.jpg',
    imageAlt: 'Kotetsu unbreakable melee weapon in Resident Evil Requiem inventory screen',
  },
  {
    title: 'Hidden Safe Codes & Optional Rewards',
    category: 'Collectibles',
    description: 'Safes scattered through the facility contain handgun ammo, healing items, crafting materials and collectible charms. The combination is always hidden in a nearby memo, note or environmental clue.',
    href: '/puzzles/safe-code',
    image: '/images/requiem_survival_guide_search_results_safe_code_046.jpg',
    imageAlt: 'Resident Evil Requiem safe code search result with combination hint',
  },
  {
    title: 'Quartz Key Secrets',
    category: 'Progression Keys',
    description: 'Three Quartz pieces — including the Moon Quartz — are hidden across the Care Center. Collecting all three opens the Central Hall door and unlocks the path to the Courtyard.',
    href: '/puzzles/moon-quartz-box',
    image: '/images/item_moon-quartz.jpg',
    imageAlt: 'Moon Quartz key item from Resident Evil Requiem',
  },
  {
    title: 'Blood Analyzer Crafting Unlocks',
    category: 'Optional Upgrade',
    description: 'Optional Blood Analyzer puzzles in the Blood Lab unlock powerful healing recipes and late-game ammo recipes. Skipping them makes the final chapters harder.',
    href: '/puzzles/blood-analyzer',
    image: '/images/requiem_survival_guide_library_puzzle_solution_038.jpg',
    imageAlt: 'Blood Analyzer logic puzzle interface in Resident Evil Requiem',
  },
  {
    title: 'Emily Save Route',
    category: 'Hidden Ending Condition',
    description: 'Keep Emily alive through the Research Wing sequence to unlock the Save Emily ending path and additional post-credits dialogue.',
    href: '/story/endings',
    image: '/images/requiem_survival_guide_ending_explained_010.jpg',
    imageAlt: 'Resident Evil Requiem ending scene showing Emily story branch',
    spoiler: true,
  },
  {
    title: 'Elpis Final Choice',
    category: 'Ending Unlock',
    description: 'At the end of the game, choose whether to release or destroy Elena / Elpis. Each choice branches into a different ending, with Save Emily + Destroy Elpis considered the true ending.',
    href: '/story/endings',
    image: '/images/requiem_survival_guide_ending_explained_011.jpg',
    imageAlt: 'Final Elpis choice scene in Resident Evil Requiem',
    spoiler: true,
  },
];

const tips = [
  {
    title: 'Check Every File',
    description: 'Files, memos and sticky notes often hide safe combinations, key codes, and lore hints. Read every document in a room before moving on.',
    icon: 'lucide:file-text',
  },
  {
    title: 'Explore Optional Rooms',
    description: 'Hidden rooms and backtracking paths contain extra ammo, herbs, charms, and collectible files. Many are locked behind optional keys.',
    icon: 'lucide:door-open',
  },
  {
    title: 'Save Before Endgame',
    description: 'Create a manual save before the final Elpis choice and Emily sequence to unlock all endings without replaying the entire campaign.',
    icon: 'lucide:save',
  },
  {
    title: 'Replay for New Game+',
    description: 'Post-game unlocks like the Kotetsu are designed for New Game+ or challenge runs. Use them to clear higher difficulties or speed-run chapters.',
    icon: 'lucide:repeat',
  },
];

const easterEggs = [
  'Classic Resident Evil-style typewriter and item box callbacks hidden in safe rooms.',
  'Environmental notes reference Spencer Mansion and Raccoon City incidents.',
  'The name "Elpis" mirrors the Greek myth of Pandora\'s box, tying into the outbreak theme.',
];

const related = [
  {
    title: 'Kotetsu Weapon Guide',
    description: 'Stats, unlock method and best use cases for the unbreakable post-game melee weapon.',
    href: '/weapons/kotetsu',
    image: '/images/requiem_survival_guide_weapons_database_059.jpg',
    imageAlt: 'Kotetsu weapon stats and unlock requirements',
  },
  {
    title: 'Endings Explained',
    description: 'All four endings, the true ending route, and how Emily and Elpis shape the final outcome.',
    href: '/story/endings',
    image: '/images/requiem_survival_guide_ending_explained_012.jpg',
    imageAlt: 'Resident Evil Requiem endings explained',
  },
  {
    title: 'Safe Codes',
    description: 'How to find every safe combination and what rewards to expect inside.',
    href: '/puzzles/safe-code',
    image: '/images/requiem_survival_guide_search_results_safe_code_047.jpg',
    imageAlt: 'Safe code locations and rewards in Resident Evil Requiem',
  },
  {
    title: 'Blood Analyzer',
    description: 'Optional logic puzzles that unlock powerful late-game crafting recipes.',
    href: '/puzzles/blood-analyzer',
    image: '/images/requiem_survival_guide_library_puzzle_solution_039.jpg',
    imageAlt: 'Blood Analyzer optional puzzle solution',
  },
];

const faqs = [
  {
    question: 'What are the best Resident Evil Requiem secrets to find?',
    answer: 'Top priorities include the Kotetsu unlockable weapon, all safe codes for extra supplies, the optional Blood Analyzer crafting recipes, and the collectible files that explain the Elpis lore.',
  },
  {
    question: 'How do you unlock the Kotetsu in Resident Evil Requiem?',
    answer: 'The Kotetsu is unlocked after completing the main campaign. It typically appears in the item box for New Game+ or challenge mode runs, giving you an unbreakable melee weapon.',
  },
  {
    question: 'Are safes worth opening in Resident Evil Requiem?',
    answer: 'Yes. Safes contain valuable resources such as handgun ammo, healing items, gunpowder, and collectible charms. The code is always hidden nearby, so check every document.',
  },
  {
    question: 'What determines the endings in Resident Evil Requiem?',
    answer: 'Endings are determined by two main factors: whether Emily survives the Research Wing and whether you choose to release or destroy Elpis at the final decision point.',
  },
  {
    question: 'Where can I find the Moon Quartz?',
    answer: 'The Moon Quartz is one of three Quartz pieces required to open the Central Hall door. It is found in the Chairman\'s Office on the second floor of the West Wing.',
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://requiemguide.com/' },
    { '@type': 'ListItem', position: 2, name: 'Secrets & Unlockables', item: 'https://requiemguide.com/secrets' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const extraSchema = [breadcrumbSchema, faqSchema];
---

<MainLayout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
  currentPath="/secrets"
  extraSchema={extraSchema}
>
  <Breadcrumb
    items={[
      { label: 'Secrets & Unlockables', href: '/secrets' },
    ]}
  />

  <section class="mb-12">
    <div class="flex items-center gap-3 mb-4">
      <span class="p-2 rounded-lg bg-horror-red/10 text-horror-red">
        <Icon name="lucide:sparkles" class="w-6 h-6" />
      </span>
      <h1 class="text-3xl sm:text-4xl font-bold text-horror-text">Secrets & Unlockables</h1>
    </div>
    <p class="text-lg text-horror-text-secondary max-w-3xl">
      A curated list of Resident Evil Requiem secrets, unlockable weapons, hidden collectibles, safe codes, optional puzzles, and the ending conditions that reward thorough exploration.
    </p>
  </section>

  <section class="mb-16">
    <h2 class="text-2xl font-bold text-horror-text mb-6">Top Secrets & Unlockables</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
      {secrets.map((secret) => {
        if (secret.spoiler) {
          return (
            <div class="group flex flex-col rounded-xl border border-horror-border bg-horror-surface/50 overflow-hidden transition-all hover:border-horror-red/50 hover:-translate-y-1 hover:shadow-2xl hover:shadow-horror-red/10 h-full">
              <div class="relative aspect-video overflow-hidden bg-horror-bg">
                <img
                  src={secret.image}
                  alt={secret.imageAlt}
                  width="512"
                  height="288"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover"
                />
                <span class="absolute top-2 right-2 px-2 py-1 text-xs font-bold uppercase bg-horror-red text-white rounded-md">
                  Spoiler
                </span>
              </div>
              <div class="p-5 flex flex-col flex-grow">
                <div class="flex items-center gap-2 mb-3">
                  <span class="text-xs font-semibold uppercase tracking-wider text-horror-red">{secret.category}</span>
                </div>
                <h3 class="text-lg font-bold text-horror-text mb-2">
                  {secret.title}
                </h3>
                <details class="spoiler text-sm">
                  <summary class="cursor-pointer list-none">
                    <span class="inline-flex items-center gap-1 font-medium text-horror-red">
                      <span class="spoiler-label">Reveal spoiler</span>
                      <Icon name="lucide:eye" class="w-4 h-4" />
                    </span>
                  </summary>
                  <p class="text-horror-text-secondary mb-4 mt-2">{secret.description}</p>
                  <a
                    href={secret.href}
                    class="inline-flex items-center gap-1 font-medium text-horror-red hover:underline"
                  >
                    <span>Read full guide</span>
                    <Icon name="lucide:arrow-right" class="w-4 h-4" />
                  </a>
                </details>
              </div>
            </div>
          );
        }
        return (
          <a
            href={secret.href}
            class="group flex flex-col rounded-xl border border-horror-border bg-horror-surface/50 overflow-hidden transition-all hover:border-horror-red/50 hover:-translate-y-1 hover:shadow-2xl hover:shadow-horror-red/10 h-full"
          >
            <div class="relative aspect-video overflow-hidden bg-horror-bg">
              <img
                src={secret.image}
                alt={secret.imageAlt}
                width="512"
                height="288"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            </div>
            <div class="p-5 flex flex-col flex-grow">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs font-semibold uppercase tracking-wider text-horror-red">{secret.category}</span>
              </div>
              <h3 class="text-lg font-bold text-horror-text mb-2 group-hover:text-horror-red transition-colors">
                {secret.title}
              </h3>
              <p class="text-sm text-horror-text-secondary mb-4 flex-grow">{secret.description}</p>
              <div class="flex items-center gap-1 text-sm font-medium text-horror-red">
                <span>Read guide</span>
                <Icon name="lucide:arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-1" />
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <section class="mb-16">
    <h2 class="text-2xl font-bold text-horror-text mb-6">Treasure-Hunting Tips</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {tips.map((tip) => (
        <div class="p-5 rounded-xl border border-horror-border bg-horror-surface/50">
          <div class="flex items-center gap-3 mb-2">
            <Icon name={tip.icon} class="w-5 h-5 text-horror-red" />
            <h3 class="font-bold text-horror-text">{tip.title}</h3>
          </div>
          <p class="text-sm text-horror-text-secondary">{tip.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mb-16">
    <div class="p-6 sm:p-8 rounded-2xl border border-horror-border bg-horror-surface/50">
      <h2 class="text-2xl font-bold text-horror-text mb-4">Easter Eggs & References</h2>
      <p class="text-horror-text-secondary mb-4">
        Beyond unlockables, Resident Evil Requiem hides several callbacks to classic Resident Evil lore. Keep an eye out for:
      </p>
      <ul class="space-y-2">
        {easterEggs.map((egg) => (
          <li class="flex items-start gap-2 text-sm text-horror-text-secondary">
            <Icon name="lucide:egg" class="w-5 h-5 text-horror-red shrink-0 mt-0.5" />
            <span>{egg}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="mb-16">
    <div class="p-6 sm:p-8 rounded-2xl border border-horror-border bg-horror-surface/50">
      <h2 class="text-2xl font-bold text-horror-text mb-4">Related Secrets Guides</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {related.map((item) => (
          <a href={item.href} class="group flex flex-col rounded-xl border border-horror-border overflow-hidden hover:border-horror-red/50 transition-colors">
            <div class="aspect-video overflow-hidden bg-horror-bg">
              <img
                src={item.image}
                alt={item.imageAlt}
                width="512"
                height="288"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            </div>
            <div class="p-4">
              <h3 class="font-bold text-horror-text mb-1 group-hover:text-horror-red transition-colors">{item.title}</h3>
              <p class="text-sm text-horror-text-secondary">{item.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <FAQSection faqs={faqs} title="Secrets & Unlockables FAQ" />

  <script is:inline>
    (function() {
      document.querySelectorAll('details.spoiler').forEach(function(details) {
        details.addEventListener('toggle', function() {
          var label = details.querySelector('.spoiler-label');
          if (label) {
            label.textContent = details.open ? 'Hide spoiler' : 'Reveal spoiler';
          }
        });
      });
    })();
  </script>
</MainLayout>
