---
import MainLayout from '../layouts/MainLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FAQSection from '../components/FAQSection.astro';
import { Icon } from 'astro-icon/components';

const title = 'Resident Evil Requiem Secrets, Unlockables & Collectibles Guide';
const description = 'Discover Resident Evil Requiem secrets, unlockable weapons, hidden collectibles, safe codes, post-game rewards, and the choices needed to unlock every ending.';

const keywords = [
  'resident evil requiem secrets',
  'resident evil requiem unlockables',
  'resident evil requiem hidden collectibles',
  'resident evil requiem kotetsu unlock',
  'resident evil requiem safe codes',
  'resident evil requiem post game rewards',
  'resident evil requiem easter eggs',
  'resident evil requiem all endings',
];

const secrets = [
  {
    title: 'Kotetsu Unbreakable Melee Weapon',
    category: 'Unlockable Weapon',
    description: 'Complete the main campaign to unlock the Kotetsu, an unbreakable post-game melee weapon. It usually appears in the item box during New Game+ or challenge runs.',
    href: '/weapons/kotetsu',
  },
  {
    title: 'Hidden Safe Codes & Optional Rewards',
    category: 'Collectibles',
    description: 'Safes scattered through the facility contain handgun ammo, healing items, crafting materials and collectible charms. The combination is always hidden in a nearby memo, note or environmental clue.',
    href: '/puzzles/safe-code',
  },
  {
    title: 'Quartz Key Secrets',
    category: 'Progression Keys',
    description: 'Three Quartz pieces — including the Moon Quartz — are hidden across the Care Center. Collecting all three opens the Central Hall door and unlocks the path to the Courtyard.',
    href: '/puzzles/moon-quartz-box',
  },
  {
    title: 'Blood Analyzer Crafting Unlocks',
    category: 'Optional Upgrade',
    description: 'Optional Blood Analyzer puzzles in the Blood Lab unlock powerful healing recipes and late-game ammo recipes. Skipping them makes the final chapters harder.',
    href: '/puzzles/blood-analyzer',
  },
  {
    title: 'Emily Save Route',
    category: 'Hidden Ending Condition',
    description: 'Keep Emily alive through the Research Wing sequence to unlock the Save Emily ending path and additional post-credits dialogue.',
    href: '/story/endings',
  },
  {
    title: 'Elpis Final Choice',
    category: 'Ending Unlock',
    description: 'At the end of the game, choose whether to release or destroy Elena / Elpis. Each choice branches into a different ending, with Save Emily + Destroy Elpis considered the true ending.',
    href: '/story/endings',
  },
];

const tips = [
  {
    title: 'Check Every File',
    description: 'Files, memos and sticky notes often hide safe combinations, key codes, and lore hints. Read every document in a room before moving on.',
    icon: 'lucide:file-text',
  },
  {
    title: 'Explore Optional Rooms',
    description: 'Hidden rooms and backtracking paths contain extra ammo, herbs, charms, and collectible files. Many are locked behind optional keys.',
    icon: 'lucide:door-open',
  },
  {
    title: 'Save Before Endgame',
    description: 'Create a manual save before the final Elpis choice and Emily sequence to unlock all endings without replaying the entire campaign.',
    icon: 'lucide:save',
  },
  {
    title: 'Replay for New Game+',
    description: 'Post-game unlocks like the Kotetsu are designed for New Game+ or challenge runs. Use them to clear higher difficulties or speed-run chapters.',
    icon: 'lucide:repeat',
  },
];

const faqs = [
  {
    question: 'What are the best Resident Evil Requiem secrets to find?',
    answer: 'Top priorities include the Kotetsu unlockable weapon, all safe codes for extra supplies, the optional Blood Analyzer crafting recipes, and the collectible files that explain the Elpis lore.',
  },
  {
    question: 'How do you unlock the Kotetsu in Resident Evil Requiem?',
    answer: 'The Kotetsu is unlocked after completing the main campaign. It typically appears in the item box for New Game+ or challenge mode runs, giving you an unbreakable melee weapon.',
  },
  {
    question: 'Are safes worth opening in Resident Evil Requiem?',
    answer: 'Yes. Safes contain valuable resources such as handgun ammo, healing items, gunpowder, and collectible charms. The code is always hidden nearby, so check every document.',
  },
  {
    question: 'What determines the endings in Resident Evil Requiem?',
    answer: 'Endings are determined by two main factors: whether Emily survives the Research Wing and whether you choose to release or destroy Elpis at the final decision point.',
  },
  {
    question: 'Where can I find the Moon Quartz?',
    answer: 'The Moon Quartz is one of three Quartz pieces required to open the Central Hall door. It is found in the Chairman\'s Office on the second floor of the West Wing.',
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://requiemguide.com/' },
    { '@type': 'ListItem', position: 2, name: 'Secrets & Unlockables', item: 'https://requiemguide.com/secrets' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<MainLayout
  title={title}
  description={description}
  keywords={keywords}
  currentPath="/secrets"
>
  <div slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </div>

  <Breadcrumb
    items={[
      { label: 'Secrets & Unlockables', href: '/secrets' },
    ]}
  />

  <section class="mb-12">
    <div class="flex items-center gap-3 mb-4">
      <span class="p-2 rounded-lg bg-horror-red/10 text-horror-red">
        <Icon name="lucide:sparkles" class="w-6 h-6" />
      </span>
      <h1 class="text-3xl sm:text-4xl font-bold text-horror-text">Secrets & Unlockables</h1>
    </div>
    <p class="text-lg text-horror-text-secondary max-w-3xl">
      A curated list of Resident Evil Requiem secrets, unlockable weapons, hidden collectibles, safe codes, optional puzzles, and the ending conditions that reward thorough exploration.
    </p>
  </section>

  <section class="mb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
      {secrets.map((secret) => (
        <a
          href={secret.href}
          class="group flex flex-col rounded-xl border border-horror-border bg-horror-surface/50 p-5 transition-all hover:border-horror-red/50 hover:-translate-y-1 hover:shadow-2xl hover:shadow-horror-red/10 h-full"
        >
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xs font-semibold uppercase tracking-wider text-horror-red">{secret.category}</span>
          </div>
          <h3 class="text-lg font-bold text-horror-text mb-2 group-hover:text-horror-red transition-colors">
            {secret.title}
          </h3>
          <p class="text-sm text-horror-text-secondary mb-4 flex-grow">{secret.description}</p>
          <div class="flex items-center gap-1 text-sm font-medium text-horror-red">
            <span>Read guide</span>
            <Icon name="lucide:arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-1" />
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="mb-16">
    <h2 class="text-2xl font-bold text-horror-text mb-6">Treasure-Hunting Tips</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {tips.map((tip) => (
        <div class="p-5 rounded-xl border border-horror-border bg-horror-surface/50">
          <div class="flex items-center gap-3 mb-2">
            <Icon name={tip.icon} class="w-5 h-5 text-horror-red" />
            <h3 class="font-bold text-horror-text">{tip.title}</h3>
          </div>
          <p class="text-sm text-horror-text-secondary">{tip.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mb-16">
    <div class="p-6 sm:p-8 rounded-2xl border border-horror-border bg-horror-surface/50">
      <h2 class="text-2xl font-bold text-horror-text mb-4">Related Secrets Guides</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="/weapons/kotetsu" class="block p-4 rounded-xl border border-horror-border hover:border-horror-red/50 transition-colors">
          <h3 class="font-bold text-horror-text mb-1">Kotetsu Weapon Guide</h3>
          <p class="text-sm text-horror-text-secondary">Stats, unlock method and best use cases for the unbreakable post-game melee weapon.</p>
        </a>
        <a href="/story/endings" class="block p-4 rounded-xl border border-horror-border hover:border-horror-red/50 transition-colors">
          <h3 class="font-bold text-horror-text mb-1">Endings Explained</h3>
          <p class="text-sm text-horror-text-secondary">All four endings, the true ending route, and how Emily and Elpis shape the final outcome.</p>
        </a>
        <a href="/puzzles/safe-code" class="block p-4 rounded-xl border border-horror-border hover:border-horror-red/50 transition-colors">
          <h3 class="font-bold text-horror-text mb-1">Safe Codes</h3>
          <p class="text-sm text-horror-text-secondary">How to find every safe combination and what rewards to expect inside.</p>
        </a>
        <a href="/puzzles/blood-analyzer" class="block p-4 rounded-xl border border-horror-border hover:border-horror-red/50 transition-colors">
          <h3 class="font-bold text-horror-text mb-1">Blood Analyzer</h3>
          <p class="text-sm text-horror-text-secondary">Optional logic puzzles that unlock powerful late-game crafting recipes.</p>
        </a>
      </div>
    </div>
  </section>

  <FAQSection faqs={faqs} title="Secrets & Unlockables FAQ" />
</MainLayout>
