---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { Icon } from 'astro-icon/components';

const title = 'Resident Evil Requiem Locations - All Maps, Areas & Key Zones';
const description = 'Explore every Resident Evil Requiem location. Browse all maps, areas, zones, and key rooms from the Rhodes Hill Care Center and beyond.';
const keywords = [
  'resident evil requiem locations',
  'resident evil requiem maps',
  'resident evil requiem areas',
  'resident evil requiem rhodes hill',
  'resident evil requiem facility',
  'resident evil requiem key rooms',
  'resident evil requiem zones',
];

const items = await getCollection('item');
const enemies = await getCollection('enemy');
const weapons = await getCollection('weapon');
const bosses = await getCollection('boss');
const puzzles = await getCollection('puzzle');
const walkthroughs = await getCollection('walkthrough');

const allEntries = [...items, ...enemies, ...weapons, ...bosses, ...puzzles, ...walkthroughs];

const locationMap = new Map<string, { name: string; count: number; types: Set<string>; firstEntry: any }>();

for (const entry of allEntries) {
  const location = entry.data.location;
  if (!location || location.length < 2) continue;
  const key = location.toLowerCase().trim();
  const existing = locationMap.get(key);
  if (existing) {
    existing.count += 1;
    existing.types.add(entry.collection);
  } else {
    locationMap.set(key, {
      name: location,
      count: 1,
      types: new Set([entry.collection]),
      firstEntry: entry,
    });
  }
}

const locations = Array.from(locationMap.values()).sort((a, b) => b.count - a.count);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://requiemguide.com' },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: 'https://requiemguide.com/locations' },
  ],
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Resident Evil Requiem Locations',
  numberOfItems: locations.length,
  itemListElement: locations.map((loc, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: loc.name,
  })),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Where does Resident Evil Requiem take place?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Resident Evil Requiem takes place primarily at the Rhodes Hill Care Center, a remote medical facility overrun by a bioweapon outbreak.',
      },
    },
    {
      '@type': 'Question',
      name: 'What are the main locations in Resident Evil Requiem?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The main locations include the Rhodes Hill Care Center, the East Wing, the research wing, the church, and the rooftop areas.',
      },
    },
  ],
};
---

<MainLayout
  title={title}
  description={description}
  keywords={keywords}
  currentPath="/locations"
  extraSchema={[breadcrumbSchema, itemListSchema, faqSchema]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb items={[{ label: 'Locations', href: '/locations' }]} />

    <header class="mb-12">
      <p class="text-horror-red font-semibold tracking-widest uppercase text-sm mb-4">Locations</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-horror-text mb-4">Resident Evil Requiem Locations</h1>
      <p class="text-xl text-horror-text-secondary max-w-2xl">
        Discover every key area, room, and zone in Resident Evil Requiem. Find enemies, items, weapons, and bosses by location.
      </p>
    </header>

    <section class="mb-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {locations.map((loc) => (
          <div class="p-5 rounded-xl border border-horror-border bg-horror-surface/50">
            <div class="flex items-center gap-3 mb-2">
              <Icon name="lucide:map-pin" class="w-5 h-5 text-horror-red" />
              <div class="font-bold text-horror-text">{loc.name}</div>
            </div>
            <div class="text-sm text-horror-text-secondary mb-2">
              {loc.count} guide{loc.count > 1 ? 's' : ''} in this area
            </div>
            <div class="flex flex-wrap gap-2">
              {Array.from(loc.types).map((type) => (
                <span class="text-xs px-2 py-1 rounded-full bg-horror-bg border border-horror-border text-horror-text-muted capitalize">
                  {type}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="rounded-xl border border-horror-border bg-horror-surface p-5 sm:p-6">
      <h2 class="text-2xl font-bold text-horror-text mb-4">About Resident Evil Requiem Locations</h2>
      <p class="text-horror-text-secondary leading-relaxed mb-4">
        The locations in Resident Evil Requiem are tightly connected to the story. Rhodes Hill Care Center is more than a backdrop — it is the source of the outbreak and the mystery that Grace, Leon, and Emily must unravel.
      </p>
      <p class="text-horror-text-secondary leading-relaxed">
        For item locations, visit the Item Locations page. For enemy and boss strategies, see the Enemies Database and Boss Guides.
      </p>
    </section>
  </div>
</MainLayout>
