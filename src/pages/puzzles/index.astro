---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import GuideCard from '../../components/GuideCard.astro';
import { Icon } from 'astro-icon/components';

const title = 'Resident Evil Requiem Puzzle Solutions';
const description = 'Complete solutions for every puzzle in Resident Evil Requiem, including safe codes, door locks, symbol puzzles, library puzzle, logic puzzles, key items and hidden mechanisms. Step-by-step codes, locations and rewards.';

const puzzles = await getCollection('puzzle');
const sortedPuzzles = puzzles.sort((a, b) => {
  const diffOrder = { Easy: 1, Medium: 2, Hard: 3 };
  return (diffOrder[a.data.difficulty] || 0) - (diffOrder[b.data.difficulty] || 0);
});

const typeLabels: Record<string, string> = {
  'safe-code': 'Safe Codes',
  'door-lock': 'Door Locks',
  'symbol': 'Symbol Puzzles',
  'logic': 'Logic Puzzles',
  'combination': 'Combination Puzzles',
  'key-item': 'Key Item Puzzles',
  'mechanism': 'Mechanisms',
};

const typeKeywords: Record<string, string[]> = {
  'safe-code': ['safe code', 'combination lock', 'numeric code'],
  'door-lock': ['door lock', 'key code', 'locked door'],
  'symbol': ['symbol puzzle', 'quartz puzzle', 'moon sun star'],
  'logic': ['logic puzzle', 'blood analyzer', 'node puzzle'],
  'combination': ['combination puzzle', 'sequence puzzle'],
  'key-item': ['key item puzzle', 'required item', 'unlock puzzle'],
  'mechanism': ['mechanism', 'final door', 'central hall'],
};

const categories = Object.entries(typeLabels).map(([key, label]) => ({
  slug: key,
  label,
  count: puzzles.filter((p) => p.data.puzzleType === key).length,
  keywords: typeKeywords[key],
}));

const totalPuzzles = puzzles.length;
const totalRewards = puzzles.filter((p) => p.data.reward).length;
const totalLocations = new Set(puzzles.map((p) => p.data.location)).size;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://requiemguide.com' },
    { '@type': 'ListItem', position: 2, name: 'Puzzle Solutions', item: 'https://requiemguide.com/puzzles' },
  ],
};

const keywords = [
  'resident evil requiem puzzle solutions',
  'resident evil requiem safe code',
  'resident evil requiem door lock code',
  'resident evil requiem library puzzle',
  'resident evil requiem symbol puzzle',
  'resident evil requiem logic puzzle',
  'resident evil requiem blood analyzer',
  'resident evil requiem quartz puzzle',
];
---

<MainLayout
  title={title}
  description={description}
  keywords={keywords}
  currentPath="/puzzles"
  extraSchema={[breadcrumbSchema]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb items={[{ label: 'Puzzle Solutions', href: '/puzzles' }]} />

    <!-- Hero Header -->
    <header class="relative mb-12 rounded-2xl overflow-hidden border border-horror-border">
      <div class="relative h-48 sm:h-64">
        <img
          src="/images/requiem_survival_guide_library_puzzle_solution_038.jpg"
          alt="Resident Evil Requiem puzzle solutions hub: safe codes, door locks, and logic puzzles"
          width="1200"
          height="675"
          loading="eager"
          fetchpriority="high"
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-horror-bg via-horror-bg/80 to-transparent"></div>
      </div>
      <div class="p-6 sm:p-8">
        <p class="text-horror-red font-semibold tracking-widest uppercase text-sm mb-4">Puzzle Database</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-horror-text mb-4">Resident Evil Requiem Puzzle Solutions</h1>
        <p class="text-xl text-horror-text-secondary max-w-2xl">{description}</p>
      </div>
    </header>

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-12">
      <div class="p-4 rounded-xl border border-horror-border bg-horror-surface/50">
        <div class="text-xs text-horror-text-muted uppercase font-semibold mb-1">Total Puzzles</div>
        <div class="text-2xl font-bold text-horror-text">{totalPuzzles}</div>
      </div>
      <div class="p-4 rounded-xl border border-horror-border bg-horror-surface/50">
        <div class="text-xs text-horror-text-muted uppercase font-semibold mb-1">Categories</div>
        <div class="text-2xl font-bold text-horror-text">{categories.filter((c) => c.count > 0).length}</div>
      </div>
      <div class="p-4 rounded-xl border border-horror-border bg-horror-surface/50">
        <div class="text-xs text-horror-text-muted uppercase font-semibold mb-1">With Rewards</div>
        <div class="text-2xl font-bold text-horror-text">{totalRewards}</div>
      </div>
      <div class="p-4 rounded-xl border border-horror-border bg-horror-surface/50">
        <div class="text-xs text-horror-text-muted uppercase font-semibold mb-1">Locations</div>
        <div class="text-2xl font-bold text-horror-text">{totalLocations}</div>
      </div>
    </div>

    <!-- Intro -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-horror-text mb-4">About Resident Evil Requiem Puzzle Solutions</h2>
      <p class="text-horror-text-secondary leading-relaxed mb-4">
        Resident Evil Requiem is filled with puzzles that block progression and hide valuable rewards. This guide covers every puzzle solution in the game, including safe codes, locked doors, symbol puzzles, laboratory mechanisms, and key-item puzzles. Each solution page includes the exact location, required items, step-by-step inputs, the code or sequence, and the reward you receive.
      </p>
      <p class="text-horror-text-secondary leading-relaxed">
        Use the categories below to narrow your search, or jump directly to the full puzzle database. If you are stuck in a specific chapter, the walkthrough guides also link back to the relevant puzzle solutions.
      </p>
    </section>

    <!-- Categories -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-horror-text mb-4">Puzzle Categories</h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {categories.filter((c) => c.count > 0).map((cat) => (
          <a
            href={`/puzzles/${cat.slug}`}
            class="group p-5 rounded-xl border border-horror-border bg-horror-surface/50 hover:bg-horror-surface hover:border-horror-red/50 transition-all"
          >
            <div class="flex items-center justify-between mb-2">
              <span class="font-bold text-horror-text group-hover:text-horror-red transition-colors">{cat.label}</span>
              <span class="text-xs font-semibold text-horror-text-muted bg-horror-bg px-2 py-1 rounded-full">{cat.count}</span>
            </div>
            <p class="text-xs text-horror-text-secondary">{cat.keywords.join(' · ')}</p>
            <div class="mt-3 flex items-center gap-1 text-sm font-medium text-horror-red">
              <span>View category</span>
              <Icon name="lucide:arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-1" />
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- All Puzzle Database -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-horror-text mb-6">All Puzzle Solutions</h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedPuzzles.map((puzzle) => (
          <GuideCard
            href={`/puzzles/${puzzle.slug}`}
            title={`${puzzle.data.title} Solution`}
            category={puzzle.data.difficulty || 'Puzzle'}
            description={puzzle.data.description || `Solution for ${puzzle.data.title}`}
            image={puzzle.data.image || '/images/requiem_survival_guide_library_puzzle_solution_038.jpg'}
          >
            <div slot="footer" class="mt-3 pt-3 border-t border-horror-border text-xs text-horror-text-muted truncate">
              {puzzle.data.location} · {puzzle.data.reward ? `Reward: ${puzzle.data.reward}` : `Type: ${puzzle.data.puzzleType ? typeLabels[puzzle.data.puzzleType] : 'Puzzle'}`}
            </div>
          </GuideCard>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="rounded-xl border border-horror-border bg-horror-surface p-5 sm:p-6">
      <h2 class="text-2xl font-bold text-horror-text mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-horror-border bg-horror-bg">
          <h3 class="text-base font-bold text-horror-text mb-2">Where can I find all puzzle solutions in Resident Evil Requiem?</h3>
          <p class="text-sm text-horror-text-secondary">This hub lists every puzzle in the game. Use the category filters or the full database table to find the exact safe code, lock code, or symbol sequence you need.</p>
        </div>
        <div class="p-4 rounded-lg border border-horror-border bg-horror-bg">
          <h3 class="text-base font-bold text-horror-text mb-2">Are the safe codes randomized?</h3>
          <p class="text-sm text-horror-text-secondary">Some safe codes are randomized per playthrough. Always search the same room for the clue document before trying to open the safe.</p>
        </div>
        <div class="p-4 rounded-lg border border-horror-border bg-horror-bg">
          <h3 class="text-base font-bold text-horror-text mb-2">Can I return to puzzles after leaving the area?</h3>
          <p class="text-sm text-horror-text-secondary">Most puzzle locations remain accessible until the next chapter transition. Some areas become locked after story progression, so solve them as soon as possible.</p>
        </div>
      </div>
    </section>
  </div>
</MainLayout>
