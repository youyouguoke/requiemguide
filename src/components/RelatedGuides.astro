---
import GuideCard from './GuideCard.astro';

export interface Props {
  title?: string;
  guides: { slug: string; data: { title: string; description?: string | null; chapter?: number | null; image?: string | null } }[];
  currentSlug?: string;
}

const { title = 'Related Guides', guides, currentSlug } = Astro.props;

const filtered = guides.filter((g) => g.slug !== currentSlug).slice(0, 3);
---

{filtered.length > 0 && (
  <div class="mt-12">
    <h2 class="text-2xl font-bold text-horror-text mb-6">{title}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {filtered.map((guide) => (
        <GuideCard
          href={`/walkthrough/${guide.slug}`}
          title={guide.data.title}
          category="Walkthrough"
          description={guide.data.description || `Chapter ${guide.data.chapter} walkthrough`}
          image={guide.data.image}
        />
      ))}
    </div>
  </div>
)}
