---
import { Icon } from 'astro-icon/components';
import { SITE, NAV_LINKS } from '../lib/config';

export interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(`${href}/`);
};

const navItems = [
  { href: '/walkthrough', label: 'Walkthrough' },
  { href: '/puzzles', label: 'Puzzles' },
  { href: '/bosses', label: 'Bosses' },
  { href: '/database', label: 'Database', hasMegaMenu: true },
  { href: '/story/endings', label: 'Story' },
  { href: '/secrets', label: 'Secrets' },
];

const databaseLinks = [
  { href: '/weapons', label: 'Weapons', icon: 'lucide:crosshair' },
  { href: '/items', label: 'Items', icon: 'lucide:box' },
  { href: '/enemies', label: 'Enemies', icon: 'lucide:bug' },
  { href: '/characters', label: 'Characters', icon: 'lucide:users' },
  { href: '/locations', label: 'Locations', icon: 'lucide:map-pin' },
];
---

<header class="fixed top-0 inset-x-0 z-50 border-b border-horror-border/50 transition-all duration-300 bg-horror-bg/90 backdrop-blur-md" id="site-header">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-[72px]">
      <!-- Logo -->
      <a href="/" class="group flex flex-col justify-center text-horror-text leading-none hover:text-horror-red transition-colors">
        <span class="font-black text-lg sm:text-xl tracking-tight uppercase">Requiem</span>
        <span class="text-[10px] sm:text-xs font-semibold tracking-[0.2em] uppercase text-horror-text-secondary group-hover:text-horror-red transition-colors">Survival Guide</span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center" aria-label="Main navigation">
        {navItems.map((item) => (
          item.hasMegaMenu ? (
            <div class="relative group">
              <a
                href={item.href}
                class:list={[
                  'flex items-center gap-1 px-4 py-2.5 text-sm font-medium transition-colors whitespace-nowrap',
                  isActive(item.href)
                    ? 'text-horror-red'
                    : 'text-horror-text-secondary hover:text-horror-text',
                ]}
              >
                {item.label}
                <Icon name="lucide:chevron-down" class="w-3.5 h-3.5 opacity-60 group-hover:rotate-180 transition-transform" />
              </a>
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <div class="w-56 p-2 rounded-xl border border-horror-border bg-horror-bg/95 backdrop-blur-md shadow-2xl shadow-black/40">
                  {databaseLinks.map((link) => (
                    <a
                      href={link.href}
                      class:list={[
                        'flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors',
                        isActive(link.href)
                          ? 'text-horror-red bg-horror-red/10'
                          : 'text-horror-text-secondary hover:text-horror-text hover:bg-horror-surface',
                      ]}
                    >
                      <Icon name={link.icon} class="w-4 h-4 flex-shrink-0" />
                      {link.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class:list={[
                'px-4 py-2.5 text-sm font-medium transition-colors whitespace-nowrap',
                isActive(item.href)
                  ? 'text-horror-red'
                  : 'text-horror-text-secondary hover:text-horror-text',
              ]}
            >
              {item.label}
            </a>
          )
        ))}
      </nav>

      <!-- Right side: Search + Mobile menu -->
      <div class="flex items-center gap-1 sm:gap-2">
        <a
          href="/search"
          class="hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-full text-sm text-horror-text-secondary border border-horror-border hover:border-horror-red/50 hover:text-horror-text transition-colors"
        >
          <Icon name="lucide:search" class="w-4 h-4" />
          <span class="text-xs">Search...</span>
        </a>
        <a href="/search" class="sm:hidden p-2 rounded-lg text-horror-text-secondary hover:text-horror-text hover:bg-horror-surface transition-colors" aria-label="Search">
          <Icon name="lucide:search" class="w-5 h-5" />
        </a>

        <button
          id="mobile-menu-btn"
          type="button"
          class="md:hidden p-2 rounded-lg text-horror-text-secondary hover:text-horror-text hover:bg-horror-surface transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <Icon name="lucide:menu" class="w-6 h-6" />
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden border-t border-horror-border bg-horror-bg/98 backdrop-blur-md"
    aria-label="Mobile navigation"
  >
    <div class="max-w-7xl mx-auto px-4 py-3 space-y-1">
      {navItems.map((item) => (
        item.hasMegaMenu ? (
          <div class="space-y-1">
            <a
              href={item.href}
              class:list={[
                'block px-4 py-3 rounded-lg text-sm font-medium transition-colors',
                isActive(item.href)
                  ? 'text-horror-red bg-horror-red/10'
                  : 'text-horror-text-secondary hover:text-horror-text hover:bg-horror-surface',
              ]}
            >
              {item.label}
            </a>
            <div class="pl-4 space-y-1 border-l border-horror-border ml-4">
              {databaseLinks.map((link) => (
                <a
                  href={link.href}
                  class:list={[
                    'flex items-center gap-2 px-4 py-2 rounded-lg text-sm transition-colors',
                    isActive(link.href)
                      ? 'text-horror-red bg-horror-red/10'
                      : 'text-horror-text-secondary hover:text-horror-text hover:bg-horror-surface',
                  ]}
                >
                  <Icon name={link.icon} class="w-4 h-4" />
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class:list={[
              'block px-4 py-3 rounded-lg text-sm font-medium transition-colors',
              isActive(item.href)
                ? 'text-horror-red bg-horror-red/10'
                : 'text-horror-text-secondary hover:text-horror-text hover:bg-horror-surface',
            ]}
          >
            {item.label}
          </a>
        )
      ))}
      <a
        href="/search"
        class="flex items-center gap-2 px-4 py-3 rounded-lg text-sm font-medium text-horror-text-secondary hover:text-horror-text hover:bg-horror-surface transition-colors"
      >
        <Icon name="lucide:search" class="w-4 h-4" />
        Search
      </a>
    </div>
  </nav>
</header>

<div class="h-16 md:h-[72px]"></div>

<script is:inline>
  (function() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;

    btn.addEventListener('click', function () {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('hidden');
    });

    // Scroll-based glass effect enhancement
    const header = document.getElementById('site-header');
    if (header) {
      const updateHeader = () => {
        if (window.scrollY > 20) {
          header.classList.add('bg-horror-bg/95');
          header.classList.remove('bg-horror-bg/90');
        } else {
          header.classList.add('bg-horror-bg/90');
          header.classList.remove('bg-horror-bg/95');
        }
      };
      window.addEventListener('scroll', updateHeader, { passive: true });
      updateHeader();
    }
  })();
</script>
