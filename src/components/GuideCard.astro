---
import { Icon } from 'astro-icon/components';
import ResponsiveImage from './ResponsiveImage.astro';

export interface Props {
  href: string;
  title: string;
  category: string;
  description?: string;
  image?: string;
  variant?: 'default' | 'boss' | 'weapon' | 'character';
}

const { href, title, category, description, image, variant = 'default' } = Astro.props;

const variantStyles = {
  default: 'bg-horror-surface border-horror-border hover:border-horror-red/50',
  boss: 'bg-horror-surface border-horror-red/30 hover:border-horror-red',
  weapon: 'bg-horror-surface border-horror-green/30 hover:border-horror-green',
  character: 'bg-horror-surface border-horror-blue/30 hover:border-horror-blue',
};

const iconStyles = {
  default: 'lucide:book-open',
  boss: 'lucide:sword',
  weapon: 'lucide:crosshair',
  character: 'lucide:user',
};
---

<a href={href} class:list={['group flex flex-col rounded-xl border overflow-hidden transition-all duration-200 hover:-translate-y-1 hover:shadow-2xl hover:shadow-horror-red/10 h-full', variantStyles[variant]]}>
  {image && (
    <div class="aspect-video overflow-hidden bg-horror-bg flex-shrink-0">
      <ResponsiveImage
        src={image}
        alt={title}
        width={512}
        height={286}
        loading="lazy"
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
      />
    </div>
  )}

  <div class="flex flex-col p-5 flex-grow">
    <div class="flex items-center justify-between mb-3">
      <span class="inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-horror-red">
        <Icon name={iconStyles[variant]} class="w-3.5 h-3.5" />
        {category}
      </span>
    </div>

    <h3 class="text-lg font-bold text-horror-text mb-2 group-hover:text-horror-red transition-colors">
      {title}
    </h3>

    {description && <p class="text-sm text-horror-text-secondary line-clamp-2 mb-4">{description}</p>}

    <div class="mt-auto flex flex-col">
      <div class="inline-flex items-center self-start gap-1.5 px-3 py-1.5 rounded-full bg-horror-red/10 text-sm font-semibold text-horror-red group-hover:bg-horror-red group-hover:text-white transition-colors">
        <span>Read guide</span>
        <Icon name="lucide:arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-1" />
      </div>
      <slot name="footer" />
    </div>
  </div>
</a>
